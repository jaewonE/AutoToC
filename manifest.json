{
  "manifest_version": 3,
  "name": "AutoToC",
  "version": "1.0.2",
  "description": "Auto-generates a hoverable Table of Contents sidebar for ChatGPT conversations.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
