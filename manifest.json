{
  "manifest_version": 3,
  "name": "AutoToC",
  "version": "0.1.6",
  "description": "Auto-generates a hoverable Table of Contents sidebar for ChatGPT conversations.",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
